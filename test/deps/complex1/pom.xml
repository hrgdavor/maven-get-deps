<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.5.11</version>
        <relativePath/>
    </parent>

    <groupId>org.complex1</groupId>
    <artifactId>root</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>

    <name>root</name>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
        <hibernate-version>6.6.44.Final</hibernate-version>
        <jackson-version>2.17.2</jackson-version>
        <jetty-version>12.0.20</jetty-version>
        <spring-version>3.5.11</spring-version>
        <spring-web-version>6.2.11</spring-web-version>
        <logback.version>1.5.11</logback.version>
        <h2-version>2.4.240</h2-version>
    </properties>

    <modules>
        <module>back</module>
        <module>core</module>
        <module>module1</module>
        <module>module2</module>
    </modules>

    <!-- security override due to old version in some deps that we can not move up -->
    <dependencyManagement>
        <dependencies>
            <!-- Force the newer commons-lang3 version globally -->
            <dependency>
                <groupId>org.apache.commons</groupId>
                <artifactId>commons-lang3</artifactId>
                <version>3.18.0</version>
            </dependency>
            <dependency>
                <groupId>org.apache.logging.log4j</groupId>
                <artifactId>log4j-api</artifactId>
                <version>2.25.3</version>
            </dependency>
            <dependency>
                <groupId>org.webjars</groupId>
                <artifactId>swagger-ui</artifactId>
                <version>5.32.0</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

</project>
